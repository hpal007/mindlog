# MindLog — environment variables (committed; documents required keys, NO real values).
# Copy to .env.local and fill in real values. .env.local is gitignored.

# --- Google Gemini (the mandatory engine) ---
# https://aistudio.google.com/apikey  (server-side only; NOT NEXT_PUBLIC)
GEMINI_API_KEY=

# --- Supabase (Postgres + RLS) ---
# Project settings → API. URL/anon are public; service-role key is SECRET (server-side only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Seeded demo session (no real auth under the 1hr clock) ---
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
